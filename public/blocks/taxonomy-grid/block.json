      "type": "string",
      "default": "0px"
    },
    "cardPaddingDesktop": {
      "type": "string",
      "default": "16px 40px 40px 40px"
    },
    "cardPaddingTablet": {
      "type": "string",
      "default": "16px 34px 40px 34px"
    },
    "cardPaddingMobile": {
      "type": "string",
      "default": "16px 34px 30px 34px"
    },
    "cardMarginDesktop": {
      "type": "string",
      "default": "0px"
    },
    "cardMarginTablet": {
      "type": "string",
      "default": "0px"
    },
    "cardMarginMobile": {
      "type": "string",
      "default": "0px"
    },
    "rowGapDesktop": {
      "type": "string",
      "default": "24px"
    },
    "rowGapTablet": {
      "type": "string",
      "default": "20px"
    },
    "rowGapMobile": {
      "type": "string",
      "default": "16px"
    },
    "filterMode": {
      "type": "string",
      "default": "standard"
    },
    "categoryImageSource": {
      "type": "string",
      "default": "main"
    },
    "region": {
      "type": "string",
      "default": ""
