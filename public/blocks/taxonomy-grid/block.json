{
  "apiVersion": 3,
  "name": "kursagenten/taxonomy-grid",
  "title": "Kursagenten Taxonomi",
  "category": "kursagenten",
  "icon": "screenoptions",
  "description": "Vis kurskategorier, kurssteder eller instruktører med preset-stiler.",
  "keywords": [
    "kurs",
    "kategori",
    "instruktør",
    "sted"
  ],
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ]
  },
  "attributes": {
    "sourceType": {
      "type": "string",
      "default": "category"
    },
    "stylePreset": {
      "type": "string",
      "default": "stablet-standard"
    },
    "columnsDesktop": {
      "type": "number",
      "default": 3
    },
    "columnsTablet": {
      "type": "number",
      "default": 2
    },
    "columnsMobile": {
      "type": "number",
      "default": 1
    },
    "showImage": {
      "type": "boolean",
      "default": true
    },
    "showDescription": {
      "type": "boolean",
      "default": false
    },
    "descriptionWordLimit": {
      "type": "number",
      "default": 22
    },
    "descriptionWordLimitExtended": {
      "type": "number",
      "default": 0
    },
    "useCardDesign": {
      "type": "boolean",
      "default": true
    },
    "shadowPreset": {
      "type": "string",
      "default": "none"
    },
    "imageSize": {
      "type": "string",
      "default": "240px"
    },
    "imageAspect": {
      "type": "string",
      "default": "4/3"
