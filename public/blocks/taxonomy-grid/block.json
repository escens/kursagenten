    "descriptionColor": {
      "type": "string",
      "default": ""
    },
    "fontWeightTitle": {
      "type": "string",
      "default": "600"
    },
    "fontWeightDescription": {
      "type": "string",
      "default": "400"
    },
    "textColor": {
      "type": "string",
      "default": ""
    },
    "textAlignDesktop": {
      "type": "string",
      "default": "left"
    },
    "textAlignTablet": {
      "type": "string",
      "default": "left"
    },
    "textAlignMobile": {
      "type": "string",
      "default": "left"
    },
    "verticalAlignDesktop": {
      "type": "string",
      "default": "top"
    },
    "verticalAlignTablet": {
      "type": "string",
      "default": "top"
