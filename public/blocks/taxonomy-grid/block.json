    "imageBorderWidth": {
      "type": "string",
      "default": "0px"
    },
    "imageBorderWidthHover": {
      "type": "string",
      "default": "0px"
    },
    "imageBorderStyle": {
      "type": "string",
      "default": "solid"
    },
    "imageBorderStyleHover": {
      "type": "string",
      "default": "solid"
    },
    "imageBorderColor": {
      "type": "string",
      "default": ""
