    "locationShowInfo": {
      "type": "boolean",
      "default": false
    },
    "instructorExclude": {
      "type": "array",
      "default": []
    },
    "categoryParentSlug": {
      "type": "string",
      "default": ""
    },
    "categoryParentSlugs": {
      "type": "array",
      "default": []
    },
    "categoryLocationFilter": {
      "type": "string",
      "default": ""
    },
    "instructorNameMode": {
      "type": "string",
      "default": "standard"
    },
    "instructorImageSource": {
      "type": "string",
      "default": "standard"
    },
    "showInstructorPhone": {
      "type": "boolean",
      "default": false
    },
    "showInstructorEmail": {
      "type": "boolean",
      "default": false
    }
